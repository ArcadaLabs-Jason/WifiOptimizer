#!/bin/bash
# WiFi Optimizer - NM Dispatcher Script
# Auto-generated by WiFi Optimizer Decky plugin. Do not edit.

SETTINGS_FILE="__SETTINGS_PATH__"
SETTINGS_DIR=$(dirname "$SETTINGS_FILE")
PLUGIN_DIR="__PLUGIN_DIR__"
LOG_TAG="wifi-optimizer"

# Only fire on interface up
[ "$2" != "up" ] && exit 0

# Only fire for wifi interfaces
IFACE_TYPE=$(/usr/bin/nmcli -t -f DEVICE,TYPE dev status 2>/dev/null | grep "^${1}:" | cut -d: -f2)
[ "$IFACE_TYPE" != "wifi" ] && exit 0

IFACE="$1"

# Self-removal: if plugin directory gone, clean up
if [ ! -d "$PLUGIN_DIR" ]; then
    logger -t "$LOG_TAG" "Plugin directory gone, removing dispatcher"
    rm -f "$0"
    rm -f /etc/NetworkManager/conf.d/99-wifi-optimizer.conf
    rm -f /etc/NetworkManager/conf.d/99-wifi-optimizer-backend.conf
    rm -f /etc/modprobe.d/99-wifi-optimizer.conf
    exit 0
fi

# Read all settings in a single Python call for speed (<50ms)
if [ -f "$SETTINGS_FILE" ] && [ -r "$SETTINGS_FILE" ]; then
    eval $(python3 -c "
import json
try:
    d=json.load(open('$SETTINGS_FILE'))
    print(f'POWER_SAVE={\"True\" if d.get(\"power_save_disabled\",True) else \"False\"}')
    print(f'BUFFER_TUNING={\"True\" if d.get(\"buffer_tuning_enabled\",False) else \"False\"}')
    v=d.get('driver','unknown')
    print(f'DRIVER={v if v.isalnum() or v.replace(\"_\",\"\").isalnum() else \"unknown\"}')
    print(f'CAKE={\"True\" if d.get(\"cake_enabled\",False) else \"False\"}')
    print(f'IRQ_AFFINITY={\"True\" if d.get(\"irq_affinity_enabled\",False) else \"False\"}')
except:
    print('POWER_SAVE=True')
    print('BUFFER_TUNING=False')
    print('DRIVER=unknown')
    print('CAKE=False')
    print('IRQ_AFFINITY=False')
" 2>/dev/null)
else
    POWER_SAVE="True"
    BUFFER_TUNING="False"
    DRIVER="unknown"
    CAKE="False"
    IRQ_AFFINITY="False"
    logger -t "$LOG_TAG" "Settings missing, safe defaults only"
fi

# Guard: if python3 failed or produced no output, fall back to safe defaults
if [ -z "$POWER_SAVE" ]; then
    POWER_SAVE="True"
    BUFFER_TUNING="False"
    DRIVER="unknown"
    CAKE="False"
    IRQ_AFFINITY="False"
    logger -t "$LOG_TAG" "Settings parse failed, safe defaults only"
fi

# Apply power save
if [ "$POWER_SAVE" = "True" ]; then
    /usr/bin/iw dev "$IFACE" set power_save off 2>/dev/null
    # Driver-specific sysfs fixes
    if [ "$DRIVER" = "rtw88" ]; then
        echo Y > /sys/module/rtw88_core/parameters/disable_lps_deep 2>/dev/null
        echo Y > /sys/module/rtw88_pci/parameters/disable_aspm 2>/dev/null
    elif [ "$DRIVER" = "mt7921e" ]; then
        echo Y > /sys/module/mt7921e/parameters/disable_aspm 2>/dev/null
    fi
    # Disable PCIe ASPM for WiFi device (all drivers)
    WIFI_PCI=$(readlink -f /sys/class/net/"$IFACE"/device 2>/dev/null)
    if [ -d "$WIFI_PCI/link" ]; then
        for f in l0s_aspm l1_aspm l1_1_aspm l1_2_aspm l1_1_pcipm l1_2_pcipm; do
            echo 0 > "$WIFI_PCI/link/$f" 2>/dev/null
        done
        echo on > "$WIFI_PCI/power/control" 2>/dev/null
    fi
    logger -t "$LOG_TAG" "power_save off applied to $IFACE (driver=$DRIVER)"
fi

# Apply buffer tuning
if [ "$BUFFER_TUNING" = "True" ]; then
    /usr/bin/sysctl -w net.core.rmem_max=16777216 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.wmem_max=16777216 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.rmem_default=1048576 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.wmem_default=1048576 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_max_backlog=5000 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_budget=600 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_budget_usecs=8000 >/dev/null 2>&1
    /usr/bin/sysctl -w net.ipv4.tcp_slow_start_after_idle=0 >/dev/null 2>&1
    /usr/bin/ip link set "$IFACE" txqueuelen 2000 2>/dev/null
    logger -t "$LOG_TAG" "buffer tuning applied"
fi

# Apply CAKE QoS
if [ "$CAKE" = "True" ]; then
    /usr/bin/modprobe sch_cake 2>/dev/null || /usr/sbin/modprobe sch_cake 2>/dev/null
    PHYRATE=$(/usr/bin/iw dev "$IFACE" link 2>/dev/null | grep "tx bitrate" | awk '{print $3}' | cut -d. -f1)
    if [ -n "$PHYRATE" ] && [ "$PHYRATE" -gt 20 ]; then
        BW=$(( PHYRATE * 85 / 100 ))
        [ "$BW" -lt 20 ] && BW=20
    else
        BW=100
    fi
    if /usr/bin/tc qdisc replace dev "$IFACE" root cake bandwidth ${BW}mbit diffserv4 nat wash ack-filter 2>/dev/null; then
        logger -t "$LOG_TAG" "CAKE QoS applied: ${BW}mbit on $IFACE"
    else
        logger -t "$LOG_TAG" "CAKE QoS failed on $IFACE (sch_cake may not be available)"
    fi
fi

# Apply IRQ affinity pinning (driver-aware to avoid pinning unrelated IRQs)
if [ "$IRQ_AFFINITY" = "True" ]; then
    IRQ_PATTERN="$IFACE"
    case "$DRIVER" in
        ath11k_pci) IRQ_PATTERN="ath11k|mhi|$IFACE" ;;
        mt7921e)    IRQ_PATTERN="mt7921|mt76|$IFACE" ;;
        rtw88)      IRQ_PATTERN="rtw88|rtl_pci|rtw_pci|$IFACE" ;;
        iwlwifi)    IRQ_PATTERN="iwlwifi|$IFACE" ;;
    esac
    PINNED=0
    for irq in $(grep -iE "$IRQ_PATTERN" /proc/interrupts 2>/dev/null | awk -F: '{print $1}' | tr -d ' '); do
        [ "$irq" -eq "$irq" ] 2>/dev/null || continue
        echo 2 > /proc/irq/$irq/smp_affinity 2>/dev/null && PINNED=$((PINNED+1))
    done
    [ "$PINNED" -gt 0 ] && logger -t "$LOG_TAG" "IRQ affinity: pinned $PINNED IRQs to CPU 1 for $IFACE"
fi

# Record enforcement timestamp
date +%s > "$SETTINGS_DIR/last_enforced" 2>/dev/null

exit 0
